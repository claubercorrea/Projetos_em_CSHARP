@model Produtos.Models.Usuario

@{
    ViewData["Title"] = "Cadastro";
}

<div class="container mt-5">
    <h2>Cadastro</h2>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }

    <form asp-action="Cadastro" method="post">
        <div class="form-group mt-3">
            <input asp-for="Nome" class="form-control" placeholder="Nome" required />
            <span asp-validation-for="Nome" class="text-danger"></span>
        </div>

        <div class="form-group mt-3">
            <input asp-for="Email" class="form-control" placeholder="Email" type="email" required />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="form-group mt-3">
            <input asp-for="Senha" class="form-control" type="password" placeholder="Senha" required />
            <span asp-validation-for="Senha" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary mt-3 w-100">Cadastrar</button>
    </form>
</div>
