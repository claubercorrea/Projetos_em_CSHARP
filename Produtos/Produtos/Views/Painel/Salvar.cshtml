@model Produtos.Models.Produto

@{
    ViewData["Title"] = "Salvar Produto";
}

<h1>Salvar Produto</h1>

<div class="row">
    <div class="col-md-4">
        <form method="post" asp-action="Salvar">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="NomeProduto" class="control-label"></label>
                <input asp-for="NomeProduto" class="form-control" />
                <span asp-validation-for="NomeProduto" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="validade" class="control-label"></label>
                <input asp-for="validade" class="form-control" />
                <span asp-validation-for="validade" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Empresa" class="control-label"></label>
                <input asp-for="Empresa" class="form-control" />
                <span asp-validation-for="Empresa" class="text-danger"></span>
            </div>


            <div class="form-group mt-3">
                <input type="submit" value="Salvar" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Voltar para a lista</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}